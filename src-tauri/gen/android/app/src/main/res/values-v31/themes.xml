<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.opencodeui.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <style name="Theme.opencodeui" parent="Theme.opencodeui.Base">
        <item name="android:windowSplashScreenBackground">#1e1d1c</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenAnimationDuration">180</item>
        <item name="postSplashScreenTheme">@style/Theme.opencodeui.Base</item>
    </style>
</resources>
